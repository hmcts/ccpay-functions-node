#!groovy
//noinspection GroovyUnusedAssignment
@Library("Infrastructure")
def type = "nodejs"
def product = "ccpay"
def component = "callback-function"

def secrets = [
  'ccpay-${env}': [
     secret('payment-s2s-secret', 'S2S_KEY_PAYMENT_APP')
    ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
    [ $class: 'AzureKeyVaultSecret',
      secretType: 'Secret',
      name: secretName,
      version: '',
      envVariable: envVar
    ]
}

def vaultOverrides = [
        'preview': 'aat',
        'hmctsdemo': 'aat',

]

withPipeline(type, product, component) {
    overrideVaultEnvironments(vaultOverrides)
    disableLegacyDeployment()
    nonServiceApp()
    loadVaultSecrets(secrets)
    before('smoketest:preview') {
        echo 'Running callback-function smoke test'
        sh 'yarn test:smoke'
    }
    afterAlways('smoketest:preview') {
        echo 'Inspecting deployed Helm release metadata after preview smoke test'
        sh '''#!/usr/bin/env bash
set +e
releases=$(helm list --all -q --namespace fees-pay | grep '^ccpay-callback-function' || true)
if [ -z "$releases" ]; then
  echo 'No matching Helm releases found in fees-pay namespace'
  exit 0
fi

for release in $releases; do
  echo "===== helm get metadata $release ====="
  helm get metadata "$release" -n fees-pay || true
done
'''
    }
    afterAlways('smoketest:aat') {
        echo 'Inspecting deployed Helm release metadata after AAT smoke test'
        sh '''#!/usr/bin/env bash
set +e
releases=$(helm list --all -q --namespace fees-pay | grep '^ccpay-callback-function' || true)
if [ -z "$releases" ]; then
  echo 'No matching Helm releases found in fees-pay namespace'
  exit 0
fi

for release in $releases; do
  echo "===== helm get metadata $release ====="
  helm get metadata "$release" -n fees-pay || true
done
'''
    }
}